PORT=3000
HOST=127.0.0.1

# Feishu app credentials
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_USER_AUTH_APP_ID=
FEISHU_USER_AUTH_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_EVENT_MODE=webhook
FEISHU_READ_ACCESS_MODE=tenant
FEISHU_USER_AUTH_REDIRECT_URI=http://127.0.0.1:3000/feishu/auth/callback
FEISHU_USER_AUTH_SCOPE="im:chat:readonly im:message:readonly im:message.group_msg:get_as_user"
FEISHU_USER_TOKEN_FILE=

# Backend selection
# codex = send Feishu messages into a local Codex/OpenClaw session
# openai = call OpenAI directly
# siliconflow = call SiliconFlow directly with OpenAI-compatible chat/completions
# anthropic = call Claude directly
FEISHU_BACKEND=codex
FEISHU_SESSION_MAP={"chat:oc_123":"团队群会话","sender:ou_456":"个人会话"}
FEISHU_REPLY_MODE=summary_only
FEISHU_DIGEST_ENABLED=1
FEISHU_DIGEST_HOUR=9
FEISHU_DIGEST_MINUTE=0
FEISHU_DIGEST_PREFIX=【自动纪要】
FEISHU_DIGEST_MAX_MESSAGES=120
FEISHU_DIGEST_TARGET_CHAT_ID=
FEISHU_CROSS_CHAT_MAX_CHATS=30
FEISHU_CROSS_CHAT_MAX_MESSAGES_PER_CHAT=25
FEISHU_CROSS_CHAT_MAX_TOTAL_MESSAGES=240
FEISHU_CROSS_CHAT_CONCURRENCY=6
FEISHU_RUN_INDICATOR=1
FEISHU_RUN_INDICATOR_EMOJI_TYPE=WINK
FEISHU_BOT_OPEN_ID=
FEISHU_OWNER_OPEN_ID=

# Local Codex/OpenClaw bridge
# Leave empty to use the currently selected session in the desktop bridge.
CODEX_SESSION_TARGET=
CODEX_PYTHON_BIN=python3
CODEX_DESKTOP_BRIDGE_SCRIPT=/Users/mt/Documents/Codex/archive/tools/codex-desktop-bridge/codex_desktop_bridge.py
CODEX_BRIDGE_WORKDIR=/Users/mt/Documents/Codex
FEISHU_STATE_FILE=

# Cloudflared helpers
# QUICK_TUNNEL_TARGET_URL can be left empty to use http://127.0.0.1:${PORT}
QUICK_TUNNEL_TARGET_URL=
# For a persistent named tunnel, copy cloudflared/config.example.yml to config.yml
# and point CLOUDFLARED_CONFIG_FILE at it if you do not want the default path.
CLOUDFLARED_BIN=/opt/homebrew/bin/cloudflared
CLOUDFLARED_CONFIG_FILE=

# Direct model fallback modes
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-mini

SILICONFLOW_API_KEY=sk-...
SILICONFLOW_MODEL=Pro/zai-org/GLM-5.1
# Important: keep the trailing /v1
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Optional behavior
BOT_NAME=龙虾
SYSTEM_PROMPT="你是一个中文优先、简洁、可靠的工作助手。根据用户意图自动切换回复风格：普通聊天时自然直接；审文档时先给结论再给问题和建议；需要总结时再输出结构化结果。不要每次都套同一个模板，不要长篇解释，优先给最有用的信息。"
